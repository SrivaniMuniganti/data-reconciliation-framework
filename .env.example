# =============================================================================
# DataSync Audit — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# =============================================================================

# ---------------------------------------------------------------------------
# Azure DevOps — Test Run Publishing (optional)
# ---------------------------------------------------------------------------
# Leave blank to disable ADO publishing and save reports locally only.
ADO_ORG_URL=https://dev.azure.com/your-organisation
ADO_PROJECT=YourProjectName
ADO_PLAN_ID=12345
ADO_SUITE_ID=67890
ADO_PAT=your-personal-access-token-here

# ---------------------------------------------------------------------------
# Run Identity (used in the ADO Test Run display name)
# ---------------------------------------------------------------------------
BATCH_NAME=BATCH_001
ENV=QA
